{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.local/openapi-3.0.schema.json",
  "type": "object",
  "required": ["openapi", "info", "paths"],
  "additionalProperties": true,
  "properties": {
    "openapi": {
      "type": "string",
      "pattern": "^3\\.0\\.[0-9]+$"
    },
    "info": {
      "type": "object",
      "required": ["title", "version"],
      "additionalProperties": true,
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "description": { "type": "string" }
      }
    },
    "servers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["url"],
        "properties": {
          "url": { "type": "string", "minLength": 1 },
          "description": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "paths": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/definitions/pathItem"
      }
    },
    "components": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "schemas": {
          "type": "object",
          "additionalProperties": { "type": "object" }
        }
      }
    }
  },
  "definitions": {
    "pathItem": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": true,
      "properties": {
        "summary": { "type": "string" },
        "description": { "type": "string" },
        "get": { "$ref": "#/definitions/operation" },
        "put": { "$ref": "#/definitions/operation" },
        "post": { "$ref": "#/definitions/operation" },
        "delete": { "$ref": "#/definitions/operation" },
        "options": { "$ref": "#/definitions/operation" },
        "head": { "$ref": "#/definitions/operation" },
        "patch": { "$ref": "#/definitions/operation" },
        "trace": { "$ref": "#/definitions/operation" }
      }
    },
    "operation": {
      "type": "object",
      "required": ["responses"],
      "additionalProperties": true,
      "properties": {
        "operationId": { "type": "string", "minLength": 1 },
        "summary": { "type": "string" },
        "description": { "type": "string" },
        "parameters": {
          "type": "array",
          "items": { "type": "object" }
        },
        "requestBody": { "type": "object" },
        "responses": {
          "type": "object",
          "minProperties": 1,
          "patternProperties": {
            "^[1-5][0-9]{2}$|^default$": {
              "$ref": "#/definitions/response"
            }
          },
          "additionalProperties": false
        }
      }
    },
    "response": {
      "type": "object",
      "required": ["description"],
      "properties": {
        "description": { "type": "string" },
        "content": { "type": "object", "additionalProperties": true }
      },
      "additionalProperties": true
    }
  }
}
